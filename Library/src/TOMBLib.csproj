<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Title>Phantasma.TOMB</Title>
    <Description>Provides runtime compilation of TOMB smart contracts and tokens.</Description>
    <PackageIcon>logo.png</PackageIcon>
    <Version>1.5.3</Version>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <PackageId>Phantasma.TOMB</PackageId>
    <RepositoryUrl>https://github.com/phantasma-io/TOMB</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\logo.png">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="PhantasmaPhoenix.Core" Version="0.2.5" />
    <PackageReference Include="PhantasmaPhoenix.Cryptography" Version="0.2.2" />
    <PackageReference Include="PhantasmaPhoenix.Protocol" Version="0.2.10" />
    <PackageReference Include="PhantasmaPhoenix.VM" Version="0.1.1" />
    <PackageReference Include="PhantasmaPhoenix.NFT" Version="0.1.1" />
    <PackageReference Include="PhantasmaPhoenix.Protocol.Carbon" Version="0.2.19" />
  </ItemGroup>

</Project>
